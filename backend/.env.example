# API Security
API_KEY_SECRET=change-me-to-a-long-random-string

# Server
HOST=0.0.0.0
PORT=8001

# Data sources
TWSE_BASE_URL=https://www.twse.com.tw
TWSE_OPENAPI_URL=https://openapi.twse.com.tw
TAIFEX_BASE_URL=https://www.taifex.com.tw
TDCC_BASE_URL=https://www.tdcc.com.tw
SINOPAC_ADAPTER_URL=http://127.0.0.1:8011

# Scheduler (CST = UTC+8; 16:35 CST = 08:35 UTC)
COLLECT_HOUR_CST=16
COLLECT_MINUTE_CST=35
REPORT_HOUR_CST=18
REPORT_MINUTE_CST=0

# Request throttle (seconds between requests to avoid IP block)
REQUEST_DELAY_MIN=3
REQUEST_DELAY_MAX=6

# Email (Phase 3, optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_EMAIL_LIST=

# Environment
ENV=development
DEBUG=true
